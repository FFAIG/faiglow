<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FAI QR LED Ayna</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', sans-serif;
      background: #fff;
      color: #111;
    }

    /* ── HERO BÖLÜMÜ (FF1) ─────────────────────────────────── */
    .hero {
      position: relative;
    }

    /*
      FF1 boyutu korunur: 1919 × 878 px görünüm oranı
      DIŞ.png (sol) + İÇMEKANTURN-B.png (sağ) yan yana
    */
    .hero-clip {
      position: relative;
      width: 100%;
      overflow: hidden;
      aspect-ratio: 1919 / 1000;
    }

    .hero-split {
      position: absolute;
      inset: 0;
      display: flex;
      width: 100%;
      height: 100%;
      gap: 14px;
    }

    .hero-panel {
      flex: 1;
      position: relative;
      overflow: hidden;
    }

    .hero-panel img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
      filter: contrast(1.06) saturate(1.12) brightness(1.02);
      image-rendering: -webkit-optimize-contrast;
      image-rendering: crisp-edges;
    }

    /* ── LOGO ──────────────────────────────────────────────── */
    .hero-logo {
      position: absolute;
      top: 2%;
      left: 50%;
      transform: translateX(-50%);
      z-index: 20;
      width: 22%;
      pointer-events: none;
      filter: drop-shadow(-10px 0 8px rgba(255,255,255,0.28)) drop-shadow(10px 0 8px rgba(255,255,255,0.28));
    }

    /* ── SAĞ ÜST İKONLAR ──────────────────────────────────── */
    .top-right-icons {
      position: absolute;
      top: 28px;
      right: 36px;
      display: flex;
      align-items: center;
      gap: 22px;
      z-index: 10;
    }

    .icon-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s;
    }

    .icon-btn:hover { opacity: 0.72; }

    .icon-btn svg {
      width: 30px;
      height: 30px;
      fill: none;
      stroke: #ffffff;
      stroke-width: 1.9;
      stroke-linecap: round;
      stroke-linejoin: round;
      filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.55));
    }

    /* ── İÇERİK BÖLÜMÜ – 3 KOLON METİN ──────────────────── */
    .features {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      padding: 250px 72px 250px;
      background: #fff;
      align-items: center;
      min-height: 620px;
    }

    .feature {
      padding: 0 32px 0 0;
      text-align: center;
    }

    .feature:last-child {
      padding-right: 0;
    }

    .feature h3 {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #111;
      margin-bottom: 18px;
      line-height: 1.4;
    }

    .feature p {
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      font-weight: 300;
      line-height: 1.75;
      color: #444;
    }

    /* ── MENÜ DROPDOWN ─────────────────────────────────────── */
    .menu-wrapper {
      position: relative;
    }

    .menu-dropdown {
      display: none;
      position: absolute;
      top: calc(100% + 12px);
      right: 0;
      background: #fff;
      min-width: 240px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.15);
      z-index: 100;
      padding: 8px 0;
      border-radius: 12px;
    }

    .menu-dropdown.open {
      display: block;
    }

    .menu-dropdown a {
      display: block;
      font-family: 'Inter', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #111;
      text-decoration: none;
      padding: 14px 24px;
      transition: background 0.15s;
    }

    .menu-dropdown a:hover {
      background: #f5f5f5;
    }

    /* ── Responsive ────────────────────────────────────────── */
    @media (max-width: 900px) {
      .features {
        grid-template-columns: repeat(2, 1fr);
        padding: 60px 36px 72px;
        gap: 48px 0;
      }

      .feature { padding-right: 24px; }
    }

    @media (max-width: 540px) {
      .features {
        grid-template-columns: 1fr;
        padding: 48px 24px 64px;
        gap: 40px;
      }

      .feature { padding-right: 0; }
    }
  </style>
</head>
<body>

  <!-- FF1 HERO -->
  <section class="hero">

    <div class="hero-clip">
      <img src="TURUNCUMEK1.png" alt="FAI QR LED Ayna" style="width:100%; height:100%; object-fit:cover; display:block;" />
    </div>

    <!-- Merkez Logo -->
    <img src="FAILOGOSON.png" alt="FAI Logo" class="hero-logo" />

    <!-- Turuncu FAI7 – Logo Altı -->
    <img src="TURUNCU-FAI9.png" alt="Turuncu FAI9" style="position:absolute; top:31%; left:53.8%; transform:translateX(-50%); width:45%; z-index:15; pointer-events:none;" />

    <!-- Sağ üst köşe: Kullanıcı Girişi + Menü -->
    <div class="top-right-icons">

      <button class="icon-btn" title="Kullanıcı Girişi" aria-label="Kullanıcı Girişi">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="8" r="4" />
          <path d="M4 20c0-3.9 3.6-7 8-7s8 3.1 8 7" />
        </svg>
      </button>

      <div class="menu-wrapper">
        <button class="icon-btn" id="menuBtn" title="Menü" aria-label="Menü" onclick="toggleMenu()">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <line x1="3" y1="6"  x2="21" y2="6"  />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
        <div class="menu-dropdown" id="menuDropdown">
          <a href="dijital-yonetim.html">Dijital Yönetim Sistemi</a>
          <a href="#">Dijital Etkileşimli Ayna</a>
        </div>
      </div>

    </div>
  </section>

  <!-- GERÇEK METİN – 3 KOLON -->
  <section class="features">

    <div class="feature">
      <h3>Mekanlarda Dijital Deneyim</h3>
      <p>
        QR entegre yapısı sayesinde sosyal medya, ürün tanıtımı, çekiliş &amp; marka iş birliği sistemi,
        kampanyalar, üyelik ve özel içerikler tek bir temas noktasıyla erişilebilir hale gelir.
        Mekân içinde estetik, arkasında güçlü bir dijital altyapı.
      </p>
    </div>

    <div class="feature">
      <h3>Seçkin Bağlantı Deneyimi</h3>
      <p>
        Uygulama gerektirmeden, temassız paylaşım imkânı sunar.
        Işığın sofistike yansımasıyla dikkat çekin. Tek dokunuşla
        kalıcı bir iz bırakın.
      </p>
    </div>

    <div class="feature">
      <h3>Zamansız Güncellenebilir Kimlik</h3>
      <p>
        FAI QR LED Işıklı Ayna üzerindeki QR alanı, dijital profilinizle entegredir.
        İletişim bilgilerinizi, sosyal medya hesaplarınızı veya markanıza ait
        tüm detayları tek dokunuşla QR değişmeden güncelleyebilirsiniz.
      </p>
    </div>

  </section>

  <!-- SARI GÖRSEL -->
  <div style="position:relative; width:100%;">
    <img src="CCCCTURUNCU-AYNA.png" alt="Palm Ayna" style="width:100%; height:620px; display:block; object-fit:cover; object-position:center;" />
    <div style="
      position:absolute;
      inset:0;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding:0 80px;
    ">
      <h2 style="
        font-family:'Inter',sans-serif;
        font-size:28px;
        font-weight:700;
        letter-spacing:0.18em;
        text-transform:uppercase;
        color:#ffffff;
        margin-bottom:28px;
        text-shadow: 0 0 20px rgba(255,255,255,0.8), 0 0 60px rgba(255,255,255,0.4);
      ">IŞIĞIN İÇİNDE DİJİTAL GÜCÜNÜZ</h2>
      <p style="
        font-family:'Inter',sans-serif;
        font-size:17px;
        font-weight:400;
        letter-spacing:0.12em;
        text-transform:uppercase;
        color:#ffffff;
        line-height:2;
        max-width:100%;
        width:100%;
        text-shadow: 0 0 20px rgba(255,255,255,0.8), 0 0 60px rgba(255,255,255,0.4);
      ">QR KODLU LED AYNA ÜZERİNDEN ERİŞİLEN İÇERİKLER, HER KULLANICI İÇİN ÖZEL OLARAK KURGULANIR.<br/>
      HER KULLANICI, KENDİ DİJİTAL ALANININ SAHİBİDİR.</p>
    </div>
  </div>

  <!-- ALT BEYAZ FON -->
  <div style="width:100%; min-height:620px; padding:250px 72px; background:#fff; display:flex; align-items:center; justify-content:center;">
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:350px; max-width:1200px; width:100%;">

    <div style="text-align:center;">
      <h3 style="font-family:'Inter',sans-serif; font-size:14px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#111; margin-bottom:18px;">KİŞİSELLEŞTİRME</h3>
      <p style="font-family:'Inter',sans-serif; font-size:15px; font-weight:300; line-height:1.75; color:#444;">
        QR içeriğini ve tasarım detaylarını özelleştirin.<br/>
        Tek dokunuşla kendi dijital deneyiminizi oluşturun.<br/>
        Işığı, QR'ı ve tasarımı size göre yapılandırın.
      </p>
    </div>

    <div style="text-align:center;">
      <h3 style="font-family:'Inter',sans-serif; font-size:14px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#111; margin-bottom:18px;">İLETİŞİM</h3>
      <p style="font-family:'Inter',sans-serif; font-size:15px; font-weight:300; line-height:1.75; color:#444;">
        E-mail, İnstagram<br/>
        aracılığıyla bize ulaşabilirsiniz.
      </p>
    </div>

  </div>
  </div>

  <!-- ALT SİYAH FON -->
  <div style="position:relative; width:100%; min-height:620px; padding:250px 72px; background:#000; display:flex; align-items:center; justify-content:center;">
    <img src="FAILOGOSON.png" alt="FAI Logo" style="position:absolute; top:8%; left:50%; transform:translateX(-50%); width:100px;" />
    <a href="https://www.instagram.com/fai.glow/" target="_blank" style="position:absolute; bottom:8%; left:50%; transform:translateX(-50%);">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <circle cx="12" cy="12" r="4"/>
        <circle cx="17.5" cy="6.5" r="1" fill="#ffffff" stroke="none"/>
      </svg>
    </a>
    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:120px; max-width:1200px; width:100%; text-align:center;">

      <div>
        <h3 style="font-family:'Inter',sans-serif; font-size:11px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#fff; margin-bottom:18px;">ONLINE</h3>
        <p style="font-family:'Inter',sans-serif; font-size:13.5px; font-weight:300; line-height:1.75; color:#aaa;">QR Oluşturun</p>
      </div>

      <div>
        <h3 style="font-family:'Inter',sans-serif; font-size:11px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#fff; margin-bottom:18px;">BİZE ULAŞIN</h3>
        <p style="font-family:'Inter',sans-serif; font-size:13.5px; font-weight:300; line-height:1.75; color:#aaa;">E-mail</p>
      </div>

      <div>
        <h3 style="font-family:'Inter',sans-serif; font-size:11px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#fff; margin-bottom:18px;">FAI</h3>
        <p style="font-family:'Inter',sans-serif; font-size:13.5px; font-weight:300; line-height:1.75; color:#aaa;">
          <a href="gizlilik.html" style="color:#aaa; text-decoration:none;">Gizlilik Sözleşmesi</a><br/>
          <a href="cerez.html" style="color:#aaa; text-decoration:none;">Çerez Politikası</a><br/>
          © 2026 FAI Tüm hakları saklıdır.
        </p>
      </div>

    </div>
  </div>

  <script>
    function toggleMenu() {
      const dropdown = document.getElementById('menuDropdown');
      dropdown.classList.toggle('open');
    }

    document.addEventListener('click', function(e) {
      const btn = document.getElementById('menuBtn');
      const dropdown = document.getElementById('menuDropdown');
      if (!btn.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.classList.remove('open');
      }
    });
  </script>

  <script>
    if (history.scrollRestoration) history.scrollRestoration = 'manual';
    window.addEventListener('load', function() { window.scrollTo(0, 0); });
  </script>

</body>
</html>
